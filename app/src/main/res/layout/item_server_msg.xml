<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="7dp">

    <!-- Ligne du haut : avatar + infos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Avatar dans CardView (aligné en haut) -->
        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            android:layout_gravity="top">

            <ImageView
                android:id="@+id/profilUserImgDiscussionItemServer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar" />
        </androidx.cardview.widget.CardView>

        <!-- Texte à droite -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"

            android:layout_weight="1">

            <!-- Nom + Heure -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <TextView
                    android:id="@+id/usernameDiscussionItemServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gloire mukoma"
                    android:textColor="@color/gray"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/createdAtDiscussionItemServer"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 1 h"
                    android:textColor="@color/gray"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Texte contenu -->
            <TextView
                android:id="@+id/txtMessageDiscussionServer"
                android:layout_marginTop="1dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/low_white"
                android:text="message"
                android:textSize="12sp"
                android:maxLines="3"/>
        </LinearLayout>
    </LinearLayout>

        <!-- Image de l’article dans CardView, indentée -->
